<?xml version="1.0"?>
<robot name="arm_1dof" xmlns:xacro="http://www.ros.org/wiki/xacro">

    <xacro:include filename="macros.xacro" />
    <xacro:include filename="materials.xacro" />

    <material name="Red"><color rgba="0.8 0.0 0.0 1.0" /></material>
    <material name="Green"><color rgba="0.0 1.0 0.0 1.0" /></material>

    <link name="base_link"></link>

    <joint name="base_link_joint" type="fixed">
        <parent link="base_link"/>
        <child link="chassis"/>
        <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <link name='chassis'>
      <collision name='chassis_collision'>
        <geometry><box size="0.2 0.15 0.05"/></geometry>
      </collision>
      <visual name='chassis_visual'>
        <geometry><box size="0.2 0.15 0.05"/></geometry>
      </visual>
      <inertial>
        <mass value="0.5"/>
        <inertia ixx="0.00104" ixy="0" ixz="0" iyy="0.0026" iyz="0" izz="0.00177"/>
      </inertial>
    </link>

    <gazebo reference="chassis"><material>Gazebo/Red</material></gazebo>

    <xacro:macro name="wheel" params="name x y">
        <link name="${name}">
            <inertial>
                <mass value="0.025"/>
                <inertia ixx="0.00016" ixy="0" ixz="0" iyy="0.00016" iyz="0" izz="0.00016"/>
            </inertial>
            <collision>
                <origin xyz="0 0 0" rpy="1.5708 0 0"/>
                <geometry><cylinder radius="0.04" length="0.03"/></geometry>
            </collision>
            <visual>
                <origin xyz="0 0 0" rpy="1.5708 0 0"/>
                <geometry><cylinder radius="0.04" length="0.03"/></geometry>
            </visual>
        </link>
        <joint name="${name}_joint" type="continuous">
            <parent link="chassis"/>
            <child link="${name}"/>
            <origin xyz="${x} ${y} 0" rpy="0 0 0"/>
            <axis xyz="0 1 0"/>
        </joint>
        <gazebo reference="${name}">
            <material>Gazebo/Green</material>
            <mu1>1.0</mu1>
            <mu2>1.0</mu2>
        </gazebo>
    </xacro:macro>

    <xacro:wheel name="wheel_FR" x="0.075" y="-0.08"/>
    <xacro:wheel name="wheel_FL" x="0.075" y="0.08"/>
    <xacro:wheel name="wheel_RR" x="-0.075" y="-0.08"/>
    <xacro:wheel name="wheel_RL" x="-0.075" y="0.08"/>

    <link name='camera_link'>
      <visual><geometry><box size="0.02 0.02 0.01"/></geometry></visual>
      <inertial><mass value="0.01"/><inertia ixx="1e-6" ixy="0" ixz="0" iyy="1e-6" iyz="0" izz="1e-6"/></inertial>
    </link>

    <joint name="camera_joint" type="fixed">
        <parent link="chassis"/>
        <child link="camera_link"/>
        <origin xyz="0.1 0 0.1" rpy="0 1.0 0"/> 
    </joint>

    <gazebo reference="camera_link">
        <sensor type="camera" name="camera1">
            <update_rate>30.0</update_rate>
            <topic>camera/image_raw</topic>
            <camera name="head">
                <horizontal_fov>1.396</horizontal_fov>
                <image><width>800</width><height>800</height><format>R8G8B8</format></image>
                <clip><near>0.02</near><far>300</far></clip>
            </camera>
            <always_on>1</always_on>
            <visualize>true</visualize>
        </sensor>
    </gazebo>

    <gazebo>
        <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
            <left_joint>wheel_FL_joint</left_joint>
            <left_joint>wheel_RL_joint</left_joint>
            <right_joint>wheel_FR_joint</right_joint>
            <right_joint>wheel_RR_joint</right_joint>
            <wheel_separation>0.16</wheel_separation>
            <wheel_radius>0.04</wheel_radius>
            <topic>cmd_vel</topic>
        </plugin>
    </gazebo>

</robot>
